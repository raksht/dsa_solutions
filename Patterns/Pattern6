#include<iostream>
using  namespace std;
class Solution {
public:
    void pattern6(int n) {
        int i,j;
        for(i=n;i>=1;i--){
            for(j=1;j<=i;j++){
                cout<<j<<"";
            }
        cout<<endl;
        }
    }
};
int main(){
    Solution obj;
    int i;
    cout<<"enter the number";
    cin>>i;
    obj.pattern6(i);
    return 0;
}
