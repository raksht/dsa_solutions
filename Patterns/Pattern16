#include <iostream>
using namespace std;
class Solution {
public:
    void pattern16(int n) {
        
        for(int i=0;i<=n;i++){
            char ch='A'+i;
            for(int j=0;j<=i;j++){
                cout<<ch<<" ";
            
            }
            cout<<endl;
        }
    }
};
int main(){
    Solution obj;
    int i;
    cout<<"Enter the number of rows:";
    cin>>i;
    obj.pattern16(i);
    return 0;
}
